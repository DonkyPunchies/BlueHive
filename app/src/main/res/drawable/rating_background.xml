<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Circle fill color -->
    <solid android:color="#262629" />

    <!-- Optional: subtle border to make it pop -->
    <stroke
        android:width="1.5dp"
        android:color="#B0000000" /> <!-- faint black outline -->

    <!-- Rounded corners -->
    <corners android:radius="4dp" />

    <!-- Define its size -->
    <size
        android:width="16dp"
        android:height="16dp" />

</shape>