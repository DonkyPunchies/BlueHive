<?xml version="1.0" encoding="utf-8"?>
<!--
    PROFILE-GENERATION OVERLAY — merges into the nonMinifiedRelease variant ONLY.

    nonMinifiedRelease is the build type the androidx baselineprofile plugin
    creates purely for generating Baseline Profiles on the Gradle-managed
    emulator. BlueHive has no launcher tile (companion app), and the emulator
    has no Off-Grid Drive host to fire the companion intent — so the generator
    enters through LoadingScreenActivity directly, which requires it to be
    exported in THIS variant.

    debug and release never read this source set: on every shipped build,
    LoadingScreenActivity keeps android:exported="false" from the main manifest.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application>
        <activity
            android:name="com.example.bluehive.LoadingScreenActivity"
            android:exported="true"
            tools:replace="android:exported" />
    </application>
</manifest>
